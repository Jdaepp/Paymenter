{
    "name": "paymenter/pterodactyl-sso",
    "description": "Pterodactyl SSO integration for Paymenter",
    "type": "paymenter-extension",
    "require": {
        "php": "^8.0",
        "firebase/php-jwt": "^6.0",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^8.0|^9.0|^10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "orchestra/testbench": "^6.0|^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Paymenter\\Extensions\\Others\\PterodactylSSO": "./"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Paymenter\\Extensions\\Others\\PterodactylSSO\\PterodactylSSOServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
